# .gitignore - Standard Python project ignores

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd

# Virtual environments
.venv/
venv/
env/
ENV/

# Testing / type checking / linter caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# Packaging and build output
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Coverage and reports
.coverage
.coverage.*
coverage.xml
htmlcov/

# Environment and secrets
.env
.env.*
!.env.example
.python-version
pip-selfcheck.json

# Editor and OS files
.vscode/
.idea/
*.sublime-workspace
.DS_Store
Thumbs.db

# Logs and local databases
*.log
*.sqlite
*.sqlite3
*.db

# Jupyter notebooks
.ipynb_checkpoints/

# PEP 582; local packages
__pypackages__/

# Cache / miscellaneous
.cache/
.eggs/
.ropeproject/
*.swp
*.swo

# Project-specific local artifacts
.velune/
qdrant_db/

# SQLite lock files and journals
*.db-wal
*.db-shm
*.sqlite-wal
*.sqlite-shm

# Local config overrides
velune.local.toml
local_settings.toml